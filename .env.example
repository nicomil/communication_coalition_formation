# Esempio di file .env per sviluppo locale
# Copia questo file come .env e compila i valori
# NOTA: .env non deve essere committato nel repository (è già in .gitignore)

# Password per l'accesso admin di oTree
OTREE_ADMIN_PASSWORD=password_sviluppo

# Modalità produzione (1 per produzione, non impostare per sviluppo)
# OTREE_PRODUCTION=1

# Secret key per Django/oTree (genera una chiave casuale per produzione)
# Per generare: python -c 'import secrets; print(secrets.token_urlsafe(50))'
# SECRET_KEY=la_tua_chiave_segreta_qui

# Database URL (configurato automaticamente su Heroku/Railway/Render)
# Per sviluppo locale, oTree usa SQLite di default
# DATABASE_URL=postgresql://user:password@localhost/dbname

